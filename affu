<!DOCTYPE html>
<html>
<head>
<title>Small Workshop Registration</title>

<style>
body {
    font-family: Arial, sans-serif;
}

.container {
    width: 60%;
    margin: auto;
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 10px gray;
}

h1 {
    text-align: center;
}

label {
    font-weight: bold;
}

input, select, textarea {
    width: 100%;
    padding: 8px;
    margin: 5px 0 15px 0;
}

button {
    padding: 10px;
    width: 48%;
    border: none;
    cursor: pointer;
}

footer {
    text-align: center;
    margin-top: 20px;
}
</style>

<script>
function validateForm() {
    var confirmBox = document.getElementById("confirm");

    if (!confirmBox.checked) {
        alert("Please confirm the details before submitting.");
        return false;
    }

    alert("Registration Successful!");
    return true;
}
</script>

</head>

<body>

<div class="container">

<h1>Web Development Workshop 2026</h1>

<p><b>Date:</b> 15 March 2026</p>
<p><b>Time:</b> 10:00 AM - 4:00 PM</p>
<p><b>Venue:</b> College Seminar Hall</p>

<hr>

<h2>Registration Form</h2>

<form onsubmit="return validateForm()">

<label>Full Name:</label>
<input type="text" required>

<label>Date of Birth:</label>
<input type="date" required>

<label>Email:</label>
<input type="email" required>

<label>Phone:</label>
<input type="tel" required>

<label>College Name:</label>
<input type="text" required>

<label>Select Event:</label>
<select>
<option>Web Development Workshop</option>
<option>AI Workshop</option>
<option>Cyber Security Workshop</option>
</select>

<label>Select Session:</label>
<select>
<option>HTML Basics</option>
<option>CSS Styling</option>
<option>JavaScript Introduction</option>
</select>

<label>Mode:</label>
<input type="radio" name="mode"> Online
<input type="radio" name="mode"> Offline

<br><br>

<label>Upload ID Proof:</label>
<input type="file">

<label>Comments:</label>
<textarea rows="3"></textarea>

<br>

<input type="checkbox" id="confirm"> I confirm that the above details are correct.

<br><br>

<button type="submit">Submit</button>
<button type="reset">Reset</button>

</form>

</div>

<footer>
Contact: workshop@email.com | Help Desk: 9876543210
</footer>

</body>
</html>
